# -----------------------------------------------------------------------------
# Printora Inventory — environment variables
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# -----------------------------------------------------------------------------

# Supabase (required for DB + Auth)
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional (later phases — uncomment when implementing)
# SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-never-expose-to-client
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

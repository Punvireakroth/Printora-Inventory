# -----------------------------------------------------------------------------
# Printora Inventory — environment variables
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# -----------------------------------------------------------------------------

# Supabase (required for DB + Auth)
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used for Auth email links (reset password); must match the deployed origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — required for `npm run db:seed-owner` (never expose to the client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Defaults for npm run db:seed-owner (override with CLI flags)
# SEED_OWNER_EMAIL=owner@printora.local
# SEED_OWNER_PASSWORD=change-me-in-production
# SEED_OWNER_FULL_NAME=Business Owner
# SEED_OWNER_LOCALE=km
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
